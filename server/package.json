{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/db/seed/index.ts",
    "db:enrich": "tsx --env-file=.env src/db/seed/enrich.ts",
    "db:import-ngsl": "tsx --env-file=.env src/db/seed/ngsl-import.ts",
    "db:generate-collections": "tsx --env-file=.env src/db/seed/generate-collections.ts",
    "db:seed-topics": "tsx --env-file=.env src/db/seed/seed-topics.ts",
    "db:update-ranks": "tsx --env-file=.env src/db/seed/update-popularity-ranks.ts",
    "db:cleanup-latin": "tsx --env-file=.env src/db/seed/cleanup-latin-translations.ts",
    "db:seed-full": "npm run db:import-ngsl && npm run db:enrich && npm run db:seed-topics && npm run db:generate-collections",
    "ai:seed": "tsx --env-file=.env src/scripts/seed-ai-content.ts",
    "ai:generate": "tsx --env-file=.env src/scripts/generate-ai-content.ts"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "kokoro-js": "^1.2.1",
    "node-cron": "^4.2.1",
    "node-edge-tts": "^1.2.10",
    "pg": "^8.18.0",
    "wink-lemmatizer": "^3.0.4"
  }
}
